# ============================================================
# search-boss 企业版部署配置
# 复制本文件为 .env 并填写实际值
# ============================================================

# ---- 应用版本 ----
APP_VERSION=1.0.0

# ---- 服务端口 ----
PORT=3000

# ---- 数据库配置 ----
DB_USER=search_boss
DB_PASSWORD=请替换为强密码
DB_NAME=search_boss_ops
DB_PORT=5432

# ---- 安全密钥 ----
AGENT_TOKEN=请替换为长随机字符串
SESSION_SECRET=请替换为长随机字符串

# ---- 浏览器自动化 ----
# Chrome 需在宿主机运行，带 --remote-debugging-port=9222
# Docker 内通过 host.docker.internal 访问宿主机
BOSS_CDP_ENDPOINT=http://host.docker.internal:9222
BOSS_CLI_ENABLED=true
SOURCE_LOOP_ENABLED=true

# ---- LLM 配置 ----
# 支持接入私有化部署的 LLM 端点，数据不外流
LLM_API_BASE=https://your-private-llm-endpoint/v1
LLM_API_KEY=请替换为LLM密钥
LLM_MODEL=gpt-5.4
